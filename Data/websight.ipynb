   "source": [
    "## # WebSight_70k — статистический анализ датасета"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "93a551fd",
   "metadata": {},
   "source": [
    "Ноутбук считает по датасету `mrm8488/WebSight_70k` метрики, аналогичные анализу WebCode2M.\n",
    "\n",
    "Метрики:\n",
    "1. Количество примеров\n",
    "2. Количество языков (если присутствует поле lang)\n",
    "3. Средний размер HTML\n",
    "4. Среднее количество DOM-узлов\n",
    "5. Размер скриншота\n",
    "6. Среднее количество CSS правил\n",
    "7. Среднее количество уникальных доменов\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1fef3225",
   "metadata": {},
   "source": [
    "## 1. Установка зависимостей"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b650ab31",
   "metadata": {},
   "outputs": [],
   "source": [
    "%pip install -q datasets lxml pandas matplotlib tqdm huggingface_hub"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9634e8d3",
   "metadata": {},
   "source": [
    "## 2. Импорты и конфигурация"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "04cc8c82",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import re\n",
    "import logging\n",
    "from urllib.parse import urlparse\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from lxml import html as lxml_html\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "HF_TOKEN = os.environ.get(\"HF_TOKEN\")\n",
    "if HF_TOKEN:\n",
    "    from huggingface_hub import login\n",
    "    login(token=HF_TOKEN, add_to_git_credential=False)\n",
    "\n",
    "import datasets\n",
    "from datasets import load_dataset\n",
    "\n",
    "logging.getLogger(\"httpx\").setLevel(logging.WARNING)\n",
    "\n",
    "DATASET = \"mrm8488/WebSight_70k\"\n",
    "SPLIT = \"train\"\n",
    "SAMPLE_SIZE = 5000\n",
    "\n",
    "print(f\"datasets: {datasets.__version__}\")\n",
    "print(f\"Датасет: {DATASET}, выборка: {SAMPLE_SIZE}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "503459b2",
   "metadata": {},
   "source": [
    "## 3. Метрика 1 — количество примеров"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "65ddfbbc",
   "metadata": {},
   "outputs": [],
   "source": [
    "ds_info = load_dataset(DATASET)\n",
    "\n",
    "TOTAL_EXAMPLES = len(ds_info[SPLIT])\n",
    "\n",
    "print(f\"[Метрика 1] Количество примеров в датасете ({SPLIT}): {TOTAL_EXAMPLES:,}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ccf5b2e8",
   "metadata": {},
   "source": [
    "## 4. Загрузка стрим-датасета"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c95ccb7e",
   "metadata": {},
   "outputs": [],
   "source": [
    "dataset = load_dataset(DATASET, streaming=True)\n",
    "dataset\n",
    "\n",
    "sample = next(iter(dataset[SPLIT].take(1)))\n",
    "print(sample.keys())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "be98826c",
   "metadata": {},
   "source": [
    "## 5. Функции-хелперы"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "61f03f49",
   "metadata": {},
   "outputs": [],
   "source": [
    "def count_dom_nodes(tree):\n",
    "    return len(tree.xpath(\".//*\")) + len(tree.xpath(\"//text()\"))\n",
    "\n",
    "_DECL_RE = re.compile(r\"[^{}:;]+:[^{}:;]+\")\n",
    "\n",
    "def _count_declarations(css_body):\n",
    "    return sum(1 for _ in _DECL_RE.finditer(css_body))\n",
    "\n",
    "def count_css_declarations(tree):\n",
    "    total = 0\n",
    "    for style_attr in tree.xpath(\"//*/@style\"):\n",
    "        total += _count_declarations(style_attr)\n",
    "\n",
    "    for style_text in tree.xpath(\"//style//text()\"):\n",
    "        for block in re.findall(r\"\\{([^{}]*)\\}\", style_text):\n",
    "            total += _count_declarations(block)\n",
    "\n",
    "    return total\n",
    "\n",
    "def count_unique_domains(tree):\n",
    "    domains = set()\n",
    "\n",
    "    for url in tree.xpath(\"//@src | //@href | //@data-src\"):\n",
    "        url = (url or \"\").strip()\n",
    "\n",
    "        if not url or url.startswith(\n",
    "            (\"#\", \"mailto:\", \"tel:\", \"javascript:\", \"data:\")\n",
    "        ):\n",
    "            continue\n",
    "\n",
    "        parse_target = \"http:\" + url if url.startswith(\"//\") else url\n",
    "\n",
    "        netloc = urlparse(parse_target).netloc.lower()\n",
    "\n",
    "        if netloc:\n",
    "            domains.add(netloc)\n",
    "\n",
    "    return len(domains)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "df85a6e0",
   "metadata": {},
   "source": [
    "## 6. Главный цикл по выборке"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0bbf0729",
   "metadata": {},
   "outputs": [],
   "source": [
    "records = []\n",
    "\n",
    "for row in tqdm(dataset[SPLIT].take(SAMPLE_SIZE),\n",
    "                total=SAMPLE_SIZE,\n",
    "                desc=\"Обработка\"):\n",
    "\n",
    "    text = (\n",
    "        row.get(\"text\")\n",
    "        or row.get(\"html\")\n",
    "        or row.get(\"code\")\n",
    "        or \"\"\n",
    "    )\n",
    "\n",
    "    img = row.get(\"image\")\n",
    "    img_w, img_h = (\n",
    "        img.size if img is not None else (None, None)\n",
    "    )\n",
    "\n",
    "    lang = row.get(\"lang\", \"unknown\")\n",
    "\n",
    "    rec = {\n",
    "        \"html_chars\": len(text),\n",
    "        \"html_bytes\": len(text.encode(\"utf-8\")),\n",
    "        \"img_w\": img_w,\n",
    "        \"img_h\": img_h,\n",
    "        \"dom_nodes\": None,\n",
    "        \"css_decls\": None,\n",
    "        \"n_domains\": None,\n",
    "        \"lang\": str(lang).lower(),\n",
    "        \"parse_ok\": False,\n",
    "    }\n",
    "\n",
    "    try:\n",
    "        tree = lxml_html.fromstring(text)\n",
    "\n",
    "        rec[\"dom_nodes\"] = count_dom_nodes(tree)\n",
    "        rec[\"css_decls\"] = count_css_declarations(tree)\n",
    "        rec[\"n_domains\"] = count_unique_domains(tree)\n",
    "        rec[\"parse_ok\"] = True\n",
    "\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "    records.append(rec)\n",
    "\n",
    "print(\n",
    "    f\"Собрано записей: {len(records)}, \"\n",
    "    f\"распарсено успешно: \"\n",
    "    f\"{sum(r['parse_ok'] for r in records)}\"\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d159a8b5",
   "metadata": {},
   "source": [
    "## 7. DataFrame с признаками"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "badeee1b",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.DataFrame(records)\n",
    "\n",
    "print(\n",
    "    f\"Размер списка признаков в памяти: \"\n",
    "    f\"{df.memory_usage(deep=True).sum()/1024**2:.2f} МБ\"\n",
    ")\n",
    "\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e3b62ef0",
   "metadata": {},
   "source": [
    "## 8. Агрегированные метрики"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ebf8c5e3",
   "metadata": {},
   "outputs": [],
   "source": [
    "ok = df[df[\"parse_ok\"]]\n",
    "\n",
    "agg = pd.DataFrame({\n",
    "    \"mean\": [\n",
    "        ok[\"html_chars\"].mean(),\n",
    "        ok[\"html_bytes\"].mean(),\n",
    "        ok[\"dom_nodes\"].mean(),\n",
    "        ok[\"css_decls\"].mean(),\n",
    "        ok[\"n_domains\"].mean(),\n",
    "        ok[\"img_h\"].mean(),\n",
    "    ],\n",
    "    \"median\": [\n",
    "        ok[\"html_chars\"].median(),\n",
    "        ok[\"html_bytes\"].median(),\n",
    "        ok[\"dom_nodes\"].median(),\n",
    "        ok[\"css_decls\"].median(),\n",
    "        ok[\"n_domains\"].median(),\n",
    "        ok[\"img_h\"].median(),\n",
    "    ],\n",
    "}, index=[\n",
    "    \"HTML символов\",\n",
    "    \"HTML байт\",\n",
    "    \"DOM-узлы\",\n",
    "    \"CSS декларации\",\n",
    "    \"Уникальные домены\",\n",
    "    \"Высота скриншота, px\"\n",
    "])\n",
    "\n",
    "agg.round(1)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "08aa9830",
   "metadata": {},
   "source": [
    "## 9. Метрика 2 — количество языков"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "aa6eb2ba",
   "metadata": {},
   "outputs": [],
   "source": [
    "if \"lang\" in df.columns:\n",
    "    lang_counts = df[\"lang\"].value_counts()\n",
    "    n_langs = df.loc[df[\"lang\"] != \"unknown\", \"lang\"].nunique()\n",
    "\n",
    "    print(f\"Уникальных языков: {n_langs}\")\n",
    "    display(lang_counts.head(15))\n",
    "else:\n",
    "    print(\"Поле lang отсутствует\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e79eb775",
   "metadata": {},
   "source": [
    "## 10. Гистограммы распределений"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f68a42cf",
   "metadata": {},
   "outputs": [],
   "source": [
    "fig, axes = plt.subplots(2, 3, figsize=(15, 8))\n",
