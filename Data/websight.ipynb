    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0b39a7ea",
   "metadata": {},
   "source": [
    "## 11. Итоговая сводка"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1203a968",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fmt(x):\n",
    "    return f\"{x:,.1f}\" if x is not None else \"n/a\"\n",
    "\n",
    "summary = pd.DataFrame([\n",
    "    (\"Количество примеров\", f\"{TOTAL_EXAMPLES:,}\"),\n",
    "    (\"Средний размер HTML\", fmt(ok[\"html_chars\"].mean())),\n",
    "    (\"Среднее число DOM-узлов\", fmt(ok[\"dom_nodes\"].mean())),\n",
    "    (\"Среднее число CSS правил\", fmt(ok[\"css_decls\"].mean())),\n",
    "    (\"Среднее число доменов\", fmt(ok[\"n_domains\"].mean()))\n",
    "], columns=[\"Метрика\", \"Значение\"])\n",
    "\n",
    "summary"
   ]
  }
    
